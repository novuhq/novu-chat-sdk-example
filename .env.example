# Required for the live bridge (POST /api/webhooks/novu).
# Reuses NOVU_SECRET_KEY as both the reply apiKey and the bridge HMAC secret.
NOVU_SECRET_KEY=
NOVU_AGENT_IDENTIFIER=

# Optional — defaults to https://api.novu.co (use https://dev.api.novu.co for dev cloud)
NOVU_API_BASE_URL=

# Optional — public URL of this bridge route; registered on boot when set.
# Use an ngrok/tunnel URL for local dev, e.g. https://xxxx.ngrok-free.app/api/webhooks/novu
# Alternatively, configure via the setup UI (saved to .novu-bridge.local.json in dev).
NOVU_BRIDGE_URL=

# Set to true to allow UI configuration in production (not recommended)
# ALLOW_UI_BRIDGE_CONFIG=true
